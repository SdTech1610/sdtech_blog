---
---
<section class="relative overflow-hidden bg-surface-950 py-20 sm:py-28 rounded-3xl mx-4 sm:mx-6 lg:mx-8 my-10 shadow-glow-lg group" aria-labelledby="freelance-heading">
  <!-- Dynamic Background Effects -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-1/4 -left-1/4 w-1/2 h-1/2 bg-brand-600/20 rounded-full blur-[120px] animate-pulse-slow"></div>
    <div class="absolute -bottom-1/4 -right-1/4 w-1/2 h-1/2 bg-accent-rose/20 rounded-full blur-[120px] animate-pulse-slow" style="animation-delay: 1s;"></div>
    <div class="absolute inset-0 bg-grid-pattern opacity-[0.05]"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Content Side -->
      <div class="animate-slide-up">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-400 text-xs font-semibold tracking-wider uppercase mb-6">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-500"></span>
          </span>
          Currently Available for Work
        </div>
        
        <h2 id="freelance-heading" class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white leading-[1.1] mb-6">
          Turning complex code into <br/>
          <span class="gradient-text">stunning products</span>
        </h2>
        
        <p class="text-lg sm:text-xl text-surface-400 leading-relaxed mb-10 max-w-xl">
          I help startups and companies build performant, accessible, and high-impact web applications using modern technologies.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="https://freelance.sdtechworld.in/contact" target="_blank" class="btn px-8 py-4 bg-white text-surface-950 hover:bg-brand-50 font-bold rounded-xl shadow-lg transition-all hover:scale-105 active:scale-95">
            Start a Project
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="ml-2 inline-block"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="https://freelance.sdtechworld.in/about" target="_blank" class="btn px-8 py-4 bg-white/5 border border-white/20 text-white hover:bg-white/10 font-bold rounded-xl backdrop-blur-sm transition-all">
            View My Process
          </a>
        </div>
      </div>

      <!-- Features Side -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6 animate-fade-in" style="animation-delay: 0.3s;">
        <div class="p-6 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-sm hover:border-brand-500/50 transition-all duration-300 group/card hover:bg-white/[0.08]">
          <div class="w-12 h-12 rounded-xl bg-brand-500/20 flex items-center justify-center text-brand-400 mb-4 group-hover/card:scale-110 group-hover/card:bg-brand-500/30 transition-all">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h3 class="text-white font-bold text-lg mb-1">Full-Stack Dev</h3>
          <p class="text-surface-400 text-sm leading-relaxed">Scalable architectures and robust APIs built for long-term growth.</p>
        </div>

        <div class="p-6 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-sm hover:border-accent-violet/50 transition-all duration-300 group/card hover:bg-white/[0.08]">
          <div class="w-12 h-12 rounded-xl bg-accent-violet/20 flex items-center justify-center text-accent-violet mb-4 group-hover/card:scale-110 group-hover/card:bg-accent-violet/30 transition-all">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.5 1.5"/><path d="M7 11l5-5"/></svg>
          </div>
          <h3 class="text-white font-bold text-lg mb-1">UI/UX Design</h3>
          <p class="text-surface-400 text-sm leading-relaxed">User-centric interfaces that blend aesthetics with seamless functionality.</p>
        </div>

        <div class="p-6 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-sm hover:border-accent-rose/50 transition-all duration-300 group/card hover:bg-white/[0.08]">
          <div class="w-12 h-12 rounded-xl bg-accent-rose/20 flex items-center justify-center text-accent-rose mb-4 group-hover/card:scale-110 group-hover/card:bg-accent-rose/30 transition-all">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3 class="text-white font-bold text-lg mb-1">Performance</h3>
          <p class="text-surface-400 text-sm leading-relaxed">Blazing fast load times and optimized Core Web Vitals for better SEO.</p>
        </div>

        <div class="p-6 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-sm hover:border-accent-cyan/50 transition-all duration-300 group/card hover:bg-white/[0.08]">
          <div class="w-12 h-12 rounded-xl bg-accent-cyan/20 flex items-center justify-center text-accent-cyan mb-4 group-hover/card:scale-110 group-hover/card:bg-accent-cyan/30 transition-all">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 12l-4-4-4 4M12 8v8"/></svg>
          </div>
          <h3 class="text-white font-bold text-lg mb-1">Consulting</h3>
          <p class="text-surface-400 text-sm leading-relaxed">Technical strategy and code reviews to help your team move faster.</p>
        </div>
      </div>
    </div>
  </div>
</section>
