---
export interface Props {
  class?: string;
  id?: string;
}

const { class: className = '', id } = Astro.props;
---

<div id={id} class={`promo-block-instance not-prose my-12 p-6 md:p-8 rounded-2xl bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 shadow-sm relative overflow-hidden group ${className}`} aria-label="Promotional Content">
  <!-- Subtle background glow -->
  <div class="absolute -bottom-24 -right-24 w-64 h-64 bg-brand-500/10 dark:bg-brand-500/20 rounded-full blur-3xl pointer-events-none group-hover:bg-brand-500/20 transition-colors duration-500"></div>
  
  <div class="relative z-10 flex flex-col md:flex-row md:items-center gap-6 justify-between">
    <div class="flex-1">
      <div class="flex items-center gap-2 mb-3">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="text-brand-500" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
          <path d="M2 17l10 5 10-5"></path>
          <path d="M2 12l10 5 10-5"></path>
        </svg>
        <span class="text-xs font-bold uppercase tracking-widest text-brand-600 dark:text-brand-400">Freelance Services</span>
      </div>
      <h3 class="text-xl md:text-2xl font-bold text-surface-900 dark:text-surface-50 mb-2 leading-tight">Need an expert for your next project?</h3>
      <p class="text-sm md:text-base text-surface-600 dark:text-surface-400 leading-relaxed max-w-xl">
        I specialize in software development, system design, and AI integrations. Whether you need an entire platform built from scratch or just expert consulting, let's create something exceptional together.
      </p>
    </div>
    <div class="shrink-0 mt-2 md:mt-0">
      <a href="https://freelance.sdtechworld.in/contact" target="_blank" class="btn-primary inline-flex gap-2 items-center px-6 py-3 whitespace-nowrap shadow-glow hover:shadow-glow-lg transition-all focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2">
        Let's work together
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</div>
