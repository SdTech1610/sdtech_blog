---
import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';

export interface Props {
  posts: CollectionEntry<'blog'>[];
  title?: string;
}

const { posts, title = 'Related Articles' } = Astro.props;
---

{posts.length > 0 && (
  <section class="mt-16 pt-10 border-t border-surface-200 dark:border-surface-800" aria-label="Related articles">
    <div class="flex items-center gap-3 mb-8">
      <div>
        <p class="section-eyebrow mb-0.5">Keep reading</p>
        <h2 class="section-heading">{title}</h2>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map(post => (
        <PostCard post={post} variant="default" loading="lazy" />
      ))}
    </div>
  </section>
)}
