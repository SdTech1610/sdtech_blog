---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  title: string;
  description: string;
  image?: string;
  article?: CollectionEntry<'blog'>['data'];
  canonicalURL?: string;
}

const {
  title,
  description,
  image = '/og-default.png',
  article,
  canonicalURL = Astro.url.href,
} = Astro.props;

const siteTitle = 'SDTechWorld — Developer Tech Blog';
const fullTitle = title === siteTitle ? title : `${title} | SDTechWorld`;
const ogImage = new URL(image, Astro.site).toString();
---

<!-- Primary Meta Tags -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="theme-color" content="#6366f1" />
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content="SDTechWorld" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<!-- <meta name="twitter:creator" content="@devpulse" /> -->

<!-- Article-specific schema -->
{article && (
  <>
    <meta property="article:published_time" content={article.pubDate.toISOString()} />
    {article.updatedDate && <meta property="article:modified_time" content={article.updatedDate.toISOString()} />}
    {article.tags?.map(tag => <meta property="article:tag" content={tag} />)}
  </>
)}

<!-- JSON-LD Schema Markup -->
{article ? (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TechArticle",
    "headline": title,
    "description": description,
    "image": ogImage,
    "datePublished": article.pubDate.toISOString(),
    "dateModified": (article.updatedDate ?? article.pubDate).toISOString(),
    "author": {
      "@type": "Person",
      "name": article.author ?? "SDTechWorld",
      "url": "https://blog.sdtechworld.in/about"
    },
    "publisher": {
      "@type": "Organization",
      "name": "SDTechWorld",
      "logo": { "@type": "ImageObject", "url": "https://blog.sdtechworld.in/logo.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalURL },
    "keywords": article.tags?.join(', ')
  })} />
) : (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "SDTechWorld",
    "description": "A modern developer tech blog platform for sharing technical insights, tutorials, and best practices.",
    "url": "https://blog.sdtechworld.in",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://blog.sdtechworld.in/blog?search={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />
)}

<!-- Favicons -->
<link rel="icon" type="image/svg+xml" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<!-- Preconnect for performance -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&family=Lora:ital,wght@0,500;0,600;1,400&display=swap" rel="stylesheet" />

<!-- RSS Feed -->
<link rel="alternate" type="application/rss+xml" title="DevPulse RSS Feed" href="/rss.xml" />
