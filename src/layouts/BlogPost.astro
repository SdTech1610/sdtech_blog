---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import CodeBlock from '../components/CodeBlock.astro';
import PromoBlock from '../components/PromoBlock.astro';
import { formatDate, tagColor, getRelatedPosts } from '../utils/blog';
import { getCollection } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
  headings: { depth: number; slug: string; text: string }[];
}

const { post, headings } = Astro.props;
const { title, description, pubDate, updatedDate, author, authorAvatar, authorBio,
        heroImage, heroAlt, tags, category, readingTime, seoTitle, seoDescription, showPromo } = post.data;

const allPosts = await getCollection('blog');
const relatedPosts = getRelatedPosts(post, allPosts, 3);
const wordCount = post.body?.split(/\s+/).length ?? 0;
const estimatedTime = readingTime ?? Math.ceil(wordCount / 200);
---

<BaseLayout
  title={seoTitle ?? title}
  description={seoDescription ?? description}
  image={heroImage}
  article={post.data}
  fullWidth={true}
>
  <!-- Reading progress -->
  <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>

  <!-- Hero image -->
  {heroImage && (
    <div class="w-full max-h-[480px] overflow-hidden">
      <img
        src={heroImage}
        alt={heroAlt ?? title}
        class="w-full max-h-[480px] object-cover"
        loading="eager"
        decoding="async"
        width="1200"
        height="480"
      />
    </div>
  )}

  <div class="max-w-8xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="lg:grid lg:grid-cols-[1fr_280px] xl:grid-cols-[1fr_300px] gap-12 items-start">

      <!-- Main article -->
      <article class="min-w-0" itemscope itemtype="https://schema.org/TechArticle">

        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center gap-2 text-sm text-surface-500 dark:text-surface-400" itemscope itemtype="https://schema.org/BreadcrumbList">
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a href="/" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors" itemprop="item"><span itemprop="name">Home</span></a>
              <meta itemprop="position" content="1" />
            </li>
            <li aria-hidden="true"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0"><path d="M9 18l6-6-6-6"/></svg></li>
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a href="/blog" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors" itemprop="item"><span itemprop="name">Blog</span></a>
              <meta itemprop="position" content="2" />
            </li>
            <li aria-hidden="true"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0"><path d="M9 18l6-6-6-6"/></svg></li>
            <li class="text-surface-700 dark:text-surface-300 truncate max-w-[200px]" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <span itemprop="name">{title}</span>
              <meta itemprop="position" content="3" />
            </li>
          </ol>
        </nav>

        <!-- Article header -->
        <header class="mb-8">
          <div class="flex flex-wrap items-center gap-2 mb-4">
            <a href={`/tags/${category.toLowerCase().replace(/\s+/g,'-')}`} class="tag tag-brand">{category}</a>
            {tags.slice(0,4).map(tag => (
              <a href={`/tags/${tag.toLowerCase().replace(/\s+/g,'-')}`} class={`tag hover:opacity-80 transition-opacity ${tagColor(tag)}`} rel="tag">
                #{tag}
              </a>
            ))}
          </div>

          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-surface-900 dark:text-surface-50 leading-tight mb-5 text-balance" itemprop="headline">
            {title}
          </h1>

          <p class="text-lg text-surface-600 dark:text-surface-400 leading-relaxed mb-6" itemprop="description">
            {description}
          </p>

          <!-- Author + Meta row -->
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 pt-5 border-t border-surface-200 dark:border-surface-800">
            <div class="flex items-center gap-3">
              {authorAvatar ? (
                <img src={authorAvatar} alt={author} class="w-10 h-10 rounded-full object-cover ring-2 ring-brand-200 dark:ring-brand-800" width="40" height="40" />
              ) : (
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-brand-400 to-accent-violet flex items-center justify-center text-white font-bold text-sm" aria-hidden="true">
                  {author.charAt(0)}
                </div>
              )}
              <div>
                <p class="text-sm font-semibold text-surface-900 dark:text-surface-100" itemprop="author" itemscope itemtype="https://schema.org/Person">
                  <span itemprop="name">{author}</span>
                </p>
                {authorBio && <p class="text-xs text-surface-500 dark:text-surface-400">{authorBio}</p>}
              </div>
            </div>
            <div class="flex items-center gap-4 text-sm text-surface-500 dark:text-surface-400">
              <div class="flex items-center gap-1.5">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                <time datetime={pubDate.toISOString()} itemprop="datePublished">{formatDate(pubDate)}</time>
              </div>
              {updatedDate && (
                <div class="flex items-center gap-1.5 text-xs">
                  <span>Updated</span>
                  <time datetime={updatedDate.toISOString()} itemprop="dateModified">{formatDate(updatedDate)}</time>
                </div>
              )}
              <div class="flex items-center gap-1.5">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
                <span itemprop="timeRequired">{estimatedTime} min read</span>
              </div>
            </div>
          </div>
        </header>

        <!-- Article body -->
        <div class="article-prose" itemprop="articleBody">
          <slot />
        </div>

        {showPromo !== false && (
          <template id="auto-promo-template">
            <PromoBlock />
          </template>
        )}

        <!-- Tags footer -->
        <footer class="mt-10 pt-6 border-t border-surface-200 dark:border-surface-800">
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-sm font-medium text-surface-500 dark:text-surface-400">Filed under:</span>
            {tags.map(tag => (
              <a href={`/tags/${tag.toLowerCase().replace(/\s+/g,'-')}`} class={`tag hover:opacity-80 transition-opacity ${tagColor(tag)}`} rel="tag">
                #{tag}
              </a>
            ))}
          </div>

          <!-- Share row -->
          <div class="flex items-center gap-3 mt-5">
            <span class="text-sm text-surface-500 dark:text-surface-400">Share:</span>
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary text-xs px-3 py-1.5"
              aria-label="Share on Twitter/X"
            >
              𝕏 / Twitter
            </a>
            <a
              href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(Astro.url.href)}&title=${encodeURIComponent(title)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary text-xs px-3 py-1.5"
              aria-label="Share on LinkedIn"
            >
              LinkedIn
            </a>
            <button
              id="copy-link-btn"
              class="btn-secondary text-xs px-3 py-1.5"
              aria-label="Copy article link"
            >
              Copy link
            </button>
          </div>
        </footer>

        <!-- Related posts -->
        <RelatedPosts posts={relatedPosts} />
      </article>

      <!-- Sidebar -->
      <aside class="hidden lg:block" aria-label="Article sidebar">
        <TableOfContents headings={headings} />
      </aside>
    </div>
  </div>

  <CodeBlock />
</BaseLayout>

<script>
  // Auto-insert promotional block
  const promoTemplate = document.getElementById('auto-promo-template');
  if (promoTemplate) {
    // Check if the author manually inserted a PromoBlock anywhere
    const existingPromo = document.querySelector('.promo-block-instance');
    if (!existingPromo) {
      const prose = document.querySelector('.article-prose');
      if (prose) {
        // Find all H2s and H3s inside the article body
        const headings = Array.from(prose.querySelectorAll('h2, h3'));
        let targetNode = null;
        
        if (headings.length >= 2) {
          // Insert it before the heading right in the middle
          const middleIndex = Math.floor(headings.length / 2);
          targetNode = headings[middleIndex];
        } else {
          // Fallback: If not enough headings, insert around ~40% through the paragraphs
          const paragraphs = Array.from(prose.querySelectorAll('p'));
          if (paragraphs.length >= 4) {
            targetNode = paragraphs[Math.floor(paragraphs.length * 0.4)];
          }
        }
        
        // Append the template content into the DOM
        if (targetNode && targetNode.parentNode) {
          targetNode.parentNode.insertBefore(promoTemplate.content.cloneNode(true), targetNode);
        } else if (prose.lastElementChild) {
          // Final fallback is putting it at the end of the post content
          prose.appendChild(promoTemplate.content.cloneNode(true));
        }
      }
    }
  }

  // Copy link button
  document.getElementById('copy-link-btn')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
      const btn = document.getElementById('copy-link-btn') as HTMLButtonElement;
      const orig = btn.textContent;
      btn.textContent = '✓ Copied!';
      setTimeout(() => { btn.textContent = orig; }, 2000);
    } catch {}
  });

  // Enhance all pre/code blocks with wrapper + copy button + lang label
  document.querySelectorAll<HTMLPreElement>('article pre').forEach(pre => {
    // Already wrapped
    if (pre.closest('.code-block-wrapper')) return;

    const wrapper = document.createElement('div');
    wrapper.className = 'code-block-wrapper not-prose my-6';

    // Detect language from class
    const codeEl = pre.querySelector('code');
    const langMatch = (codeEl?.className ?? pre.className).match(/language-(\w+)/);
    const lang = langMatch?.[1] ?? '';

    // Build header
    const header = document.createElement('div');
    header.className = 'code-block-header';
    header.innerHTML = `
      <span class="code-block-lang">${lang || 'code'}</span>
      <button class="copy-btn" aria-label="Copy code" type="button">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
          <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
        </svg>
        Copy
      </button>
    `;

    pre.parentNode?.insertBefore(wrapper, pre);
    wrapper.appendChild(header);
    wrapper.appendChild(pre);
  });
</script>
