---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getAllTags, tagColor, filterDrafts } from '../../utils/blog';

const allPosts = await getCollection('blog');
const posts = filterDrafts(allPosts);
const tags = getAllTags(posts);

const title = "Topics & Tags | DevPulse";
const description = "Explore all technical topics and tags on DevPulse, from React and Node.js to AWS and DevOps.";
---

<BaseLayout {title} {description}>
  <div class="max-w-4xl">
    <header class="mb-12">
      <p class="section-eyebrow mb-2">Topic Hub</p>
      <h1 class="text-4xl font-bold text-surface-900 dark:text-surface-50 mb-4 tracking-tight">
        Browse by <span class="gradient-text">Topic</span>
      </h1>
      <p class="text-lg text-surface-600 dark:text-surface-400">
        Everything on this platform is organized into specific technical tags to help you find exactly what you're looking for.
      </p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {[...tags.entries()].map(([tag, count]) => (
        <a 
          href={`/tags/${tag.toLowerCase().replace(/\s+/g,'-')}`} 
          class="flex items-center justify-between p-4 rounded-2xl border border-surface-200 dark:border-surface-800 bg-white dark:bg-surface-900 hover:border-brand-500 dark:hover:border-brand-500 hover:shadow-glow transition-all group"
        >
          <div class="flex items-center gap-3">
            <span class={`w-2 h-2 rounded-full ${tagColor(tag).split(' ')[0]}`}></span>
            <span class="font-semibold text-surface-900 dark:text-surface-100 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
              {tag}
            </span>
          </div>
          <span class="text-xs font-medium text-surface-500 dark:text-surface-400 bg-surface-100 dark:bg-surface-800 px-2 py-1 rounded-lg">
            {count} post{count !== 1 ? 's' : ''}
          </span>
        </a>
      ))}
    </div>

    {tags.size === 0 && (
      <div class="text-center py-20 bg-surface-100 dark:bg-surface-900/50 rounded-3xl border border-dashed border-surface-300 dark:border-surface-700">
        <p class="text-surface-500 dark:text-surface-400">No tags found yet.</p>
      </div>
    )}
  </div>
</BaseLayout>
